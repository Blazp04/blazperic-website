---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { BLOG_POSTS } from "../../data/blogPosts";

// Redirect to first blog post or show blog listing
const posts = BLOG_POSTS;
---

<BaseLayout title="Blog – Blaž Perić" description="Notes, ideas, and things I'm exploring.">
  <div class="min-h-screen bg-primary">
    <div class="scanline-overlay"></div>
    <div class="dot-grid-overlay"></div>

    <nav class="wrapper border-b border-nickel">
      <div class="flex items-center justify-between px-5 sm:px-10 py-4">
        <a href="/" class="flex items-center gap-3 text-white no-underline group">
          <svg width="20" height="20" viewBox="0 0 16 16" fill="none" class="text-grey group-hover:text-ruby transition-colors">
            <path d="M10 12L6 8L10 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <span class="font-mono text-xs text-grey group-hover:text-white transition-colors">cd ~</span>
        </a>
        <span class="text-grey/40 text-xs font-mono hidden sm:block">blazperic.com / blog</span>
      </div>
    </nav>

    <div class="wrapper wrapper--ticks border-t border-nickel">
      <div class="p-5 sm:p-10 flex flex-col gap-3 border-b border-nickel">
        <h1 class="text-heading-2 text-white">Blog</h1>
        <p class="text-grey text-sm max-w-xl">Notes, ideas, and things I'm exploring.</p>
      </div>

      <div class="divide-y divide-nickel">
        {posts.map((post) => (
          <a href={`/blog/${post.slug}`} class="group block p-5 sm:p-10 hover:bg-white/[0.02] transition-colors">
            <div class="flex items-center gap-3 flex-wrap mb-2">
              {post.tags.map((tag) => (
                <span class="text-[10px] font-mono tracking-wider uppercase border border-nickel/60 px-2 py-0.5 text-grey/60">
                  {tag}
                </span>
              ))}
            </div>
            <h2 class="text-xl text-white group-hover:text-ruby transition-colors">{post.title}</h2>
            <p class="text-grey text-sm mt-2">{post.description}</p>
            <div class="flex items-center gap-4 mt-3">
              <span class="text-grey/40 text-xs font-mono">{post.date}</span>
              <span class="text-grey/40 text-xs font-mono">{post.readTime}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
